#!/bin/bash
# Pre-commit hook (Python): lint + tests.
set -e

if [ -f ".venv/bin/python" ]; then
    PYTHON=".venv/bin/python"
elif [ -f "venv/bin/python" ]; then
    PYTHON="venv/bin/python"
else
    PYTHON="python3"
fi

echo "=== Pre-commit: ruff check ==="
$PYTHON -m ruff check .

echo "=== Pre-commit: pytest ==="
$PYTHON -m pytest tests/ -q --tb=short

# --- FGT Bug Abstraction Protocol enforcement ---
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
CRITICAL_STAGED=$(echo "$STAGED" | grep -E '^src/.*\.py$' || true)

if [ -n "$CRITICAL_STAGED" ]; then
    if [ "${FGT_SKIP:-}" = "1" ]; then
        echo "[FGT] Bypassed via FGT_SKIP=1"
    else
        DOCS_STAGED=$(echo "$STAGED" | grep -E '^(BUG_PATTERNS_{{DOMAIN}}|BACKLOG)\.md$' || true)
        if [ -z "$DOCS_STAGED" ]; then
            echo "[FGT] Pre-commit REJECTED:" >&2
            echo "  Commit touches src/ without updating BUG_PATTERNS_{{DOMAIN}}.md or BACKLOG.md." >&2
            echo "  Bypass: FGT_SKIP=1 git commit -m \"chore: ...\"" >&2
            exit 1
        fi
        TESTS_STAGED=$(echo "$STAGED" | grep -E '^tests/.*\.py$' || true)
        if [ -z "$TESTS_STAGED" ]; then
            echo "[FGT] Pre-commit REJECTED:" >&2
            echo "  Commit touches src/ without modifying any test file." >&2
            echo "  Bypass: FGT_SKIP=1 git commit -m \"chore: ...\"" >&2
            exit 1
        fi
    fi
fi

echo "=== Pre-commit: all checks passed ==="
