// PRO-* Proactive detection tests — structural scans that catch bug classes
// before they manifest. See FGT.md § Principle 7.

import { describe, it, expect } from 'vitest';
import { readFileSync } from 'fs';
import { join } from 'path';

const PROJECT_ROOT = join(import.meta.dirname, '..');

describe('PRO-PRIVACY-001: .gitignore excludes sensitive paths', () => {
  it('.gitignore excludes .env files', () => {
    const gitignore = readFileSync(join(PROJECT_ROOT, '.gitignore'), 'utf-8');
    expect(gitignore).toContain('.env');
  });
});
